#!/usr/bin/env bash
set -euo pipefail

AGENT=""
while [ $# -gt 0 ]; do
  if [ "$1" = "--agent" ]; then
    AGENT="$2"
  fi
  shift
done

if [ "$AGENT" = "code-reviewer" ]; then
  echo "fake code-reviewer invoked" > /tmp/fake-code-reviewer-invoked.marker
  echo '{"type":"result","subtype":"success","is_error":false,"result":"No blocking issues found.","total_cost_usd":0.01}'
  exit 0
fi

if [ -n "${FAKE_CLAUDE_RATE_LIMITED:-}" ]; then
  echo "fake claude invoked (rate limited)" >> /tmp/fake-claude-invoked.marker
  echo '{"type":"result","subtype":"error_rate_limit","is_error":true,"errors":["rate_limit_exceeded"],"total_cost_usd":0.0}'
  exit 0
fi

echo "fake claude invoked" > /tmp/fake-claude-invoked.marker
echo "feature output" > feature.txt
git add -A
git commit -m "Add feature.txt" >/dev/null

echo '{"type":"result","subtype":"success","is_error":false,"result":"ok","total_cost_usd":0.01}'
