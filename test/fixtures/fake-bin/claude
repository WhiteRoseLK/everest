#!/usr/bin/env bash
set -euo pipefail

ORIGINAL_ARGS="$*"

AGENT=""
while [ $# -gt 0 ]; do
  if [ "$1" = "--agent" ]; then
    AGENT="$2"
  fi
  shift
done

if [ "$AGENT" = "chat" ]; then
  echo "$ORIGINAL_ARGS" > /tmp/fake-chat-invoked.marker
  exit "${FAKE_CLAUDE_CHAT_EXIT_CODE:-0}"
fi

if [ "$AGENT" = "code-reviewer" ]; then
  echo "fake code-reviewer invoked" > /tmp/fake-code-reviewer-invoked.marker
  echo '{"type":"result","subtype":"success","is_error":false,"result":"No blocking issues found.","total_cost_usd":0.01}'
  exit 0
fi

if [ -n "${FAKE_CLAUDE_ADVANCE_ORIGIN_MAIN:-}" ]; then
  # Simulates a concurrent merge landing on origin/main while this sprint runs (e.g.
  # code-reviewer merging a different issue's PR) - used to test that the harness notices and
  # restarts (src/loop.ts restartIfMainAdvanced, issue #43). Built with plumbing commands so it
  # doesn't disturb whatever branch is currently checked out.
  new_commit=$(git commit-tree 'origin/main^{tree}' -p origin/main -m "concurrent merge on main")
  git push origin "$new_commit":refs/heads/main
fi

if [ -n "${FAKE_CLAUDE_RATE_LIMITED:-}" ]; then
  echo "fake claude invoked (rate limited)" >> /tmp/fake-claude-invoked.marker
  echo '{"type":"result","subtype":"error_rate_limit","is_error":true,"errors":["rate_limit_exceeded"],"total_cost_usd":0.0}'
  exit 0
fi

if [ -n "${FAKE_CLAUDE_BUDGET_EXCEEDED_WITH_WIP:-}" ]; then
  echo "fake claude invoked (budget exceeded, WIP left uncommitted)" >> /tmp/fake-claude-invoked.marker
  echo "partial work" > wip-file.txt
  echo '{"type":"result","subtype":"error_max_budget_usd","is_error":true,"errors":["Reached maximum budget"],"total_cost_usd":2.0}'
  exit 0
fi

if [ -n "${FAKE_CLAUDE_BUDGET_EXCEEDED:-}" ]; then
  echo "fake claude invoked (budget exceeded, no progress)" >> /tmp/fake-claude-invoked.marker
  echo '{"type":"result","subtype":"error_max_budget_usd","is_error":true,"errors":["Reached maximum budget"],"total_cost_usd":2.0}'
  exit 0
fi

if [ -n "${FAKE_CLAUDE_NO_COMMIT:-}" ]; then
  # Simulates issue-worker reporting success without ever committing anything (e.g. it explored
  # the issue but concluded there was nothing to change) - runClaudeCode (src/claude.ts) turns
  # this into a "no new commit produced" failure. Used to test that handleIssue (src/loop.ts)
  # bounds retries on this path via retryFreshSprintOrGiveUp instead of giving up unconditionally
  # after a single attempt (issue #57).
  echo "fake claude invoked (no commit produced)" >> /tmp/fake-claude-invoked.marker
  echo '{"type":"result","subtype":"success","is_error":false,"result":"nothing to do","total_cost_usd":0.01}'
  exit 0
fi

echo "fake claude invoked" > /tmp/fake-claude-invoked.marker
# Appends rather than overwriting with fixed content, and includes the current commit count, so
# repeated invocations on the same branch (retries, fixup cycles) each produce a genuinely new
# commit instead of "nothing to commit, working tree clean" aborting the script under `set -e`.
echo "feature output $(git rev-list --count HEAD)" >> feature.txt
git add -A
git commit -m "Add feature.txt" >/dev/null

echo '{"type":"result","subtype":"success","is_error":false,"result":"ok","total_cost_usd":0.01}'
