#!/usr/bin/env bash
set -euo pipefail

if [ "$1" = "issue" ] && [ "$2" = "list" ]; then
  if [[ " $* " == *" closed "* ]]; then
    echo "${FAKE_GH_ISSUE_LIST_CLOSED:-[]}"
    exit 0
  fi
  if [ -f "${FAKE_GH_ISSUE_LIST_FAIL_ONCE:-}" ]; then
    rm -f "$FAKE_GH_ISSUE_LIST_FAIL_ONCE"
    echo "fake gh: simulated transient failure" >&2
    exit 1
  fi
  # `listIssuesOpenedSince` (src/github.ts, used by `everest catchup`) is the only open-issue
  # list call that passes `--limit` - distinguishes it from the unfiltered `listOpenIssues` call
  # used by `pickNextIssue`, which shares the plain fallback below.
  if [[ " $* " == *" --limit "* ]] && [ -n "${FAKE_GH_ISSUE_LIST_OPENED_SINCE:-}" ]; then
    echo "$FAKE_GH_ISSUE_LIST_OPENED_SINCE"
    exit 0
  fi
  # Escaping the default value's own `}` characters inside `${VAR:-...}` is fragile - bash treats
  # an unescaped `}` there as closing the substitution early. Assigning it to a plain variable
  # first sidesteps that entirely.
  default_issue_list='[{"number":1,"title":"Test issue","labels":[],"createdAt":"2024-01-01T00:00:00Z"}]'
  echo "${FAKE_GH_ISSUE_LIST:-$default_issue_list}"
  exit 0
fi

if [ "$1" = "issue" ] && [ "$2" = "edit" ]; then
  if [ -n "${FAKE_GH_ISSUE_EDIT_MARKER:-}" ]; then
    echo "$@" >> "$FAKE_GH_ISSUE_EDIT_MARKER"
  fi
  exit 0
fi

if [ "$1" = "issue" ] && [ "$2" = "create" ]; then
  # Appends (not overwrites) so a single test can assert on every call when `createIssuesFromMessage`
  # (src/github.ts) splits one request into several `gh issue create` invocations. A body can
  # itself contain newlines, so each record ends with an explicit separator line rather than
  # relying on one record per line.
  if [ -n "${FAKE_GH_ISSUE_CREATE_MARKER:-}" ]; then
    { echo "$@"; echo '---FAKE_GH_ISSUE_CREATE_END---'; } >> "$FAKE_GH_ISSUE_CREATE_MARKER"
  fi
  # Increments per marker file so each call in a split gets a distinct issue number, starting at
  # 2 (matching the previous fixed-URL behavior for the common single-issue-create case).
  counter_file="${FAKE_GH_ISSUE_CREATE_MARKER:-/tmp/fake-gh-issue-create}.counter"
  n=$(cat "$counter_file" 2>/dev/null || echo 2)
  echo $((n + 1)) > "$counter_file"
  echo "https://example.invalid/issues/$n"
  exit 0
fi

if [ "$1" = "pr" ] && [ "$2" = "list" ]; then
  if [ -f "${FAKE_GH_PR_LIST_FAIL_ONCE:-}" ]; then
    rm -f "$FAKE_GH_PR_LIST_FAIL_ONCE"
    echo "fake gh: simulated transient failure" >&2
    exit 1
  fi
  # `listBlockers` (src/github.ts) passes `--label needs-human` to filter server-side. Mirror
  # that here via a dedicated env var so tests can distinguish it from the unfiltered
  # `listHarnessPullRequests`/`findResumablePullRequest` calls, which share FAKE_GH_PR_LIST.
  if [[ " $* " == *" needs-human "* ]] && [ -n "${FAKE_GH_PR_LIST_NEEDS_HUMAN:-}" ]; then
    echo "$FAKE_GH_PR_LIST_NEEDS_HUMAN"
    exit 0
  fi
  echo "${FAKE_GH_PR_LIST:-[]}"
  exit 0
fi

if [ "$1" = "pr" ] && [ "$2" = "create" ]; then
  echo "$@" > "$FAKE_GH_PR_MARKER"
  echo "https://example.invalid/pr/1"
  exit 0
fi

if [ "$1" = "pr" ] && [ "$2" = "view" ]; then
  if [ -n "${FAKE_GH_PR_VIEW:-}" ]; then
    echo "$FAKE_GH_PR_VIEW"
  else
    # Mirrors real code-reviewer behavior: it merges directly (self-approve is impossible on
    # GitHub), so reviewDecision stays null but the PR state becomes MERGED.
    echo '{"reviewDecision":null,"state":"MERGED"}'
  fi
  exit 0
fi

if [ "$1" = "pr" ] && [ "$2" = "edit" ]; then
  if [ -n "${FAKE_GH_PR_EDIT_MARKER:-}" ]; then
    echo "$@" >> "$FAKE_GH_PR_EDIT_MARKER"
  fi
  exit 0
fi

if [ "$1" = "label" ] && [ "$2" = "create" ]; then
  exit 0
fi

if [ "$1" = "issue" ] && [ "$2" = "comment" ]; then
  echo "$@" >> "$FAKE_GH_COMMENT_MARKER"
  exit 0
fi

echo "fake gh: unhandled args: $*" >&2
exit 1
