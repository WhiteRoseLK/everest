#!/usr/bin/env bash
set -euo pipefail

if [ "$1" = "issue" ] && [ "$2" = "list" ]; then
  if [[ " $* " == *" closed "* ]]; then
    echo "${FAKE_GH_ISSUE_LIST_CLOSED:-[]}"
    exit 0
  fi
  if [ -f "${FAKE_GH_ISSUE_LIST_FAIL_ONCE:-}" ]; then
    rm -f "$FAKE_GH_ISSUE_LIST_FAIL_ONCE"
    echo "fake gh: simulated transient failure" >&2
    exit 1
  fi
  echo '[{"number":1,"title":"Test issue","labels":[],"createdAt":"2024-01-01T00:00:00Z"}]'
  exit 0
fi

if [ "$1" = "issue" ] && [ "$2" = "create" ]; then
  if [ -n "${FAKE_GH_ISSUE_CREATE_MARKER:-}" ]; then
    echo "$@" > "$FAKE_GH_ISSUE_CREATE_MARKER"
  fi
  echo "https://example.invalid/issues/2"
  exit 0
fi

if [ "$1" = "pr" ] && [ "$2" = "list" ]; then
  echo "${FAKE_GH_PR_LIST:-[]}"
  exit 0
fi

if [ "$1" = "pr" ] && [ "$2" = "create" ]; then
  echo "$@" > "$FAKE_GH_PR_MARKER"
  echo "https://example.invalid/pr/1"
  exit 0
fi

if [ "$1" = "pr" ] && [ "$2" = "view" ]; then
  if [ -n "${FAKE_GH_PR_VIEW:-}" ]; then
    echo "$FAKE_GH_PR_VIEW"
  else
    # Mirrors real code-reviewer behavior: it merges directly (self-approve is impossible on
    # GitHub), so reviewDecision stays null but the PR state becomes MERGED.
    echo '{"reviewDecision":null,"state":"MERGED"}'
  fi
  exit 0
fi

if [ "$1" = "pr" ] && [ "$2" = "edit" ]; then
  if [ -n "${FAKE_GH_PR_EDIT_MARKER:-}" ]; then
    echo "$@" >> "$FAKE_GH_PR_EDIT_MARKER"
  fi
  exit 0
fi

if [ "$1" = "label" ] && [ "$2" = "create" ]; then
  exit 0
fi

if [ "$1" = "issue" ] && [ "$2" = "comment" ]; then
  echo "$@" >> "$FAKE_GH_COMMENT_MARKER"
  exit 0
fi

echo "fake gh: unhandled args: $*" >&2
exit 1
