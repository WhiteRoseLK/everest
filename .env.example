GITHUB_REPO=WhiteRoseLK/everest
CLAUDE_CODE_OAUTH_TOKEN=            # généré via `claude setup-token` (abonnement, pas de clé API)
GH_TOKEN=                          # `gh auth token` en local
MAX_BUDGET_USD_PER_ISSUE=2
MAX_BUDGET_USD_PER_REVIEW=1
MAX_CONCURRENT_REVIEWS=2           # review/fixup loops allowed to run at once, each in its own clone (issue #96)
POLL_INTERVAL_MS=60000
WATCH_POLL_INTERVAL_MS=30000       # intervalle de poll de `everest watch` (voir src/cli.ts)
BASE_RETRY_DELAY_MS=60000
MAX_RETRY_DELAY_MS=3600000
MAX_RETRY_COUNT=10
PUSH_RETRY_COUNT=3                 # tentatives de `git push` avant de retomber sur un sprint frais
PUSH_RETRY_DELAY_MS=5000
DASHBOARD_PORT=3000                # port du dashboard web en lecture seule (voir src/dashboard.ts)
DASHBOARD_BIND=127.0.0.1           # interface hôte publiée par docker-compose.yml pour ce port (0.0.0.0 pour exposer au-delà de l'hôte)
